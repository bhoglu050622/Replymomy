# Copy this file to .env.local and fill in your real values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# DodoPayments
DODO_SECRET_KEY=your-dodo-secret-key
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret
DODO_PRODUCT_GOLD=pdt_xxxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_PLATINUM=pdt_xxxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_BLACK_CARD=pdt_xxxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_TOKENS_5=pdt_xxxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_TOKENS_12=pdt_xxxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_TOKENS_30=pdt_xxxxxxxxxxxxxxxxxxxxxx

# Stream Chat
STREAM_API_KEY=your-stream-api-key
STREAM_API_SECRET=your-stream-api-secret
NEXT_PUBLIC_STREAM_API_KEY=your-stream-api-key

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Persona (KYC)
PERSONA_API_KEY=your-persona-api-key
PERSONA_TEMPLATE_ID=your-persona-template-id
PERSONA_WEBHOOK_SECRET=your-persona-webhook-secret

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cron
CRON_SECRET=your-cron-secret

# Google AI (Gemini)
GOOGLE_AI_API_KEY=your-google-ai-api-key
