# Copy this file to .env.local and fill in your real values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Admin (strict when NODE_ENV=production unless ADMIN_ENFORCE_EMAIL=false)
# Allowlisted email + email/password identity only for /admin and /api/admin.
# ADMIN_ALLOWED_EMAIL=admin@replymommy.com
# ADMIN_ENFORCE_EMAIL=true   # force strict (e.g. staging)
# ADMIN_ENFORCE_EMAIL=false  # disable strict (emergency / local prod debugging)

# DodoPayments
DODO_SECRET_KEY=your-dodo-secret-key
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret
# Active plans
DODO_PRODUCT_PRO=pdt_xxxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_UNLIMITED=pdt_xxxxxxxxxxxxxxxxxxxxxx
# Token packs
DODO_PRODUCT_TOKENS_5=pdt_xxxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_TOKENS_12=pdt_xxxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_TOKENS_30=pdt_xxxxxxxxxxxxxxxxxxxxxx
# Legacy plans (keep for existing subscribers)
DODO_PRODUCT_GOLD=pdt_xxxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_PLATINUM=pdt_xxxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_BLACK_CARD=pdt_xxxxxxxxxxxxxxxxxxxxxx

# Stream Chat
STREAM_API_KEY=your-stream-api-key
STREAM_API_SECRET=your-stream-api-secret
NEXT_PUBLIC_STREAM_API_KEY=your-stream-api-key

# Local Filesystem Storage (RECOMMENDED - fastest when app runs on same server)
# Set these to use your Hostinger disk space directly (no SFTP overhead)
# LOCAL_UPLOAD_PATH=/home/youruser/yourdomain.com/public_html/uploads
# LOCAL_UPLOAD_URL=https://yourdomain.com/uploads
# Optional CDN/public host (e.g. Cloudflare proxied domain used for media)
# CLOUDFLARE_CDN_URL=https://yourdomain.com

# Hostinger SFTP (fallback when local storage path is not accessible)
# Only used if LOCAL_UPLOAD_PATH is not set or if local writes fail
HOSTINGER_SFTP_HOST=your-server-ip
HOSTINGER_SFTP_USER=your-ssh-username
HOSTINGER_SFTP_PASS=your-ssh-password
HOSTINGER_SFTP_PORT=22
HOSTINGER_SFTP_PATH=/home/user/domains/yourdomain.com/public_html/media
HOSTINGER_MEDIA_URL=https://yourdomain.com/media

# Persona (KYC)
PERSONA_API_KEY=your-persona-api-key
PERSONA_TEMPLATE_ID=your-persona-template-id
PERSONA_WEBHOOK_SECRET=your-persona-webhook-secret

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cron
CRON_SECRET=your-cron-secret

# Google AI (Gemini)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Cloudinary (final fallback for uploads and cleanup jobs)
# Optional: PREFER_CLOUDINARY_UPLOAD=1  (use Cloudinary as primary)
# Optional: DISABLE_HOSTINGER_UPLOAD=1  (skip SFTP)
# Optional: DISABLE_LOCAL_UPLOAD=1  (skip local disk; use SFTP/Cloudinary)
# Dashboard: https://console.cloudinary.com → Product environment credentials
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
